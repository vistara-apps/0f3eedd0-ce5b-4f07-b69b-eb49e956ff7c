# Base Chain Configuration
NEXT_PUBLIC_BASE_RPC_URL=https://mainnet.base.org
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_wallet_connect_project_id

# Newsletter Service Configuration
NEXT_PUBLIC_NEWSLETTER_API_URL=https://api.mailchimp.com/3.0
NEWSLETTER_API_KEY=your_mailchimp_api_key
NEWSLETTER_LIST_ID=your_mailchimp_list_id

# Farcaster Integration
NEXT_PUBLIC_FARCASTER_HUB_URL=https://api.farcaster.xyz/v2

# IPFS Configuration
NEXT_PUBLIC_IPFS_GATEWAY=https://ipfs.io/ipfs/
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key

# Database Configuration (for production)
DATABASE_URL=postgresql://username:password@localhost:5432/nebula_arena

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_key

# Environment
NODE_ENV=development
